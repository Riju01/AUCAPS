<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>List of All Students</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
        <h2 class="test-h2-class"> Verify Following Students: </h2><br>
    <div class="job-template">
        <% students.forEach(student => { %>
            <div class="individual-template student-card">
                <% if (student) { %>
                    <h3>Name: <%= student.name %></h3>
                    <h4>Registration: <%= student.registration %></h4>
                    <h4>Department: <%= student.department %></h4>
                    <h4>Address: <%= student.address %></h4>
                <% } else { %>
                    <h3 style="color:red;">Student not found</h3>
                <% } %>
                <button class="dashProfileCss" id="dashProfile" data-type="studentDetailsVerify" data-studentid="<%= student._id %>"> See Details & Verify </button>
            </div>
        <% }) %>
    </div>
    <script src="/js/dashboard.js"></script>
</body>
</html>